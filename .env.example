NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_FILE=./data/airiq.db
JWT_SECRET=replace-with-local-secret-at-least-16-chars
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7
UPLOAD_DIR=./uploads
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@airiq.local
ENABLE_CRON=false
OPENAQ_API_KEY=
VITE_API_URL=http://localhost:4000/api/v1
# WebSocket connections reuse the API host and connect on /ws.
