{
  "name": "@airiq/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "node -e \"console.log('No backend build step needed for plain Express JavaScript')\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "node -e \"console.log('API is plain JavaScript; no TypeScript check needed')\"",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "pipeline:import": "node src/pipeline/bulk-import.js",
    "pipeline:update": "node src/pipeline/daily-update.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "vitest": "^4.1.9"
  }
}
