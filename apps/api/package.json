{
  "name": "@airiq/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --env-file=.env --watch src/server.ts",
    "build": "tsup src/server.ts src/db/migrate.ts src/db/seed.ts --format esm --dts --clean --sourcemap --out-dir dist",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "pipeline:import": "tsx --env-file=.env src/pipeline/bulk-import.ts",
    "pipeline:update": "tsx --env-file=.env src/pipeline/daily-update.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "nanoid": "^5.1.6",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.1.9"
  }
}
